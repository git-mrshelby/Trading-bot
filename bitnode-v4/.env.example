# Execution mode: paper or testnet
EXECUTION_MODE=paper

# Live market data endpoint (Binance Futures public data)
BINANCE_MARKET_BASE=https://fapi.binance.com

# Binance Futures testnet endpoint for demo trading
BINANCE_TESTNET_BASE=https://testnet.binancefuture.com

# Only required in testnet mode
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bot behavior
SCAN_INTERVAL_MS=1500
MAX_SYMBOLS=30
LEVERAGE=5
NOTIONAL_USDT=40
TAKE_PROFIT_PCT=0.0018
STOP_LOSS_PCT=0.0012
CONFIDENCE_THRESHOLD=78
DAILY_TARGET_USDT=10
DAILY_STOP_USDT=-3
